# ── Gemini Express TMS — Environment Variables ──

# App
VITE_APP_NAME=Gemini Express TMS
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api

# Database (for future backend)
DATABASE_URL=postgresql://user:password@localhost:5432/gemini_tms

# Authentication
VITE_AUTH_DOMAIN=
VITE_AUTH_CLIENT_ID=

# CargoWise
CARGOWISE_API_URL=
CARGOWISE_API_KEY=
CARGOWISE_COMPANY_CODE=

# ELD Providers
MOTIVE_API_KEY=
SAMSARA_API_TOKEN=

# Load Boards
DAT_API_KEY=
DAT_API_SECRET=
TRUCKSTOP_API_KEY=

# Factoring
TRIUMPHPAY_API_KEY=
RTS_FINANCIAL_API_KEY=

# Carrier Verification
RMIS_API_KEY=
HIGHWAY_API_KEY=

# Email (for notifications & dunning)
SENDGRID_API_KEY=
FROM_EMAIL=notifications@geminiexpress.com

# SMS (for alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# File Storage
AWS_S3_BUCKET=gemini-tms-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Customs / CBP
ACE_API_URL=
ACE_FILER_CODE=AGS

# Google Maps (route optimization)
GOOGLE_MAPS_API_KEY=
