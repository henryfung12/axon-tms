# =============================================================
# GEMINI EXPRESS TMS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# ---- App ----
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://gemini_user:gemini_pass@localhost:5432/gemini_express_dev?schema=public"

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth (JWT) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=10cdd708906b777e41e30f30dceb8eeb3fa435fd8a63b27c92daf5e15b12ad9637e4f34fa5f83339856c5f602ae919836217e4c176b92adb095ed20c3bbf6a62
JWT_REFRESH_SECRET=88cc8f8f4aeba3b50df8302568ac43176d3b9d7a551b5625054b2e113f6f2b2bcf339e1320e0ad64d6db8452c83c1c1464f0896e6a261472fbc1dd694434ef7f
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ---- AWS ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_SECRET
AWS_S3_BUCKET=gemini-express-documents

# ---- Google Maps (for geocoding + ETA) ----
GOOGLE_MAPS_API_KEY=AIzaSyBDXmVXZ-CXZXYZQuRONKOdc5mfhLFsK9g

# ---- Twilio (SMS notifications) ----
TWILIO_ACCOUNT_SID=REPLACE_WITH_YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ---- SendGrid (email) ----
SENDGRID_API_KEY=REPLACE_WITH_YOUR_SENDGRID_KEY
EMAIL_FROM=no-reply@gemini-express.com
